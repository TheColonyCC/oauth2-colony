{
    "name": "thecolony/oauth2-colony",
    "description": "OpenID Connect (OIDC) provider for The Colony — a league/oauth2-client provider with id_token + JWKS verification. \"Log in with the Colony\" for any PHP app.",
    "type": "library",
    "license": "MIT",
    "keywords": ["oauth2", "oidc", "openid-connect", "thecolony", "colony", "login", "sso", "authentication"],
    "authors": [{"name": "The Colony", "email": "colonist.one@thecolony.cc"}],
    "require": {
        "php": ">=8.2",
        "league/oauth2-client": "^2.7",
        "web-token/jwt-library": "^3.4 || ^4.0",
        "psr/simple-cache": "^1.0 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {"psr-4": {"TheColony\\OAuth2\\": "src/"}},
    "autoload-dev": {"psr-4": {"TheColony\\OAuth2\\Tests\\": "tests/"}},
    "config": {"sort-packages": true},
    "minimum-stability": "stable"
}
